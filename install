#!/usr/bin/env bash
set -euo pipefail

if [[ ! -x "$0" ]]; then
  chmod +x "$0" 2>/dev/null || true
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SERVER_ROOT="$SCRIPT_DIR/server"
SERVICE_FILE="$SCRIPT_DIR/minecraft-server.service"
RUN_USER="${SUDO_USER:-}"
if [[ -z "$RUN_USER" ]]; then
  if id -u ubuntu >/dev/null 2>&1; then
    RUN_USER="ubuntu"
  elif id -u pi >/dev/null 2>&1; then
    RUN_USER="pi"
  else
    RUN_USER="root"
  fi
fi
RUN_HOME="$(getent passwd "$RUN_USER" 2>/dev/null | cut -d: -f6 || true)"

if [[ -z "$RUN_HOME" ]]; then
  RUN_HOME="/home/$RUN_USER"
fi

is_supported_linux() {
  if [[ -f /etc/os-release ]]; then
    # shellcheck disable=SC1091
    . /etc/os-release
    case "${ID:-}" in
      ubuntu|debian)
        return 0
        ;;
    esac
    case "${ID_LIKE:-}" in
      *ubuntu*|*debian*)
        return 0
        ;;
    esac
  fi
  return 1
}

require_supported_linux() {
  if ! is_supported_linux; then
    echo "This installer is intended for Ubuntu/Debian Linux (including Ubuntu Server on Raspberry Pi)."
    exit 1
  fi
}

SUPPORTED_VERSIONS=(
  "1.20.4" "1.20.5" "1.20.6" "1.21" "1.21.1" "1.21.2" "1.21.3" "1.21.4" "1.21.5" "1.21.6" "1.21.7" "1.21.8" "1.21.9" "1.21.10" "1.21.11" "26.1" "26.1.1" "26.1.2" "26.2"
)

is_supported_version() {
  local version="$1"
  local found=0
  for supported in "${SUPPORTED_VERSIONS[@]}"; do
    if [[ "$supported" == "$version" ]]; then
      found=1
      break
    fi
  done
  return $((found == 0))
}

require_root() {
  if [[ $EUID -ne 0 ]]; then
    echo "Please run this installer with sudo: sudo ./install"
    exit 1
  fi
}

ensure_systemd() {
  if command -v systemctl >/dev/null 2>&1; then
    return 0
  fi
  echo "systemctl is not available; skipping service setup."
  return 0
}

prompt_yes_no() {
  local prompt="$1"
  if command -v whiptail >/dev/null 2>&1; then
    if whiptail --title "Installer" --yesno "$prompt" 10 60; then
      return 0
    fi
    return 1
  fi
  local answer=""
  while [[ "$answer" != "y" && "$answer" != "n" ]]; do
    read -rp "$prompt [y/n]: " answer
    answer="${answer,,}"
  done
  [[ "$answer" == "y" ]]
}

prompt_server_type() {
  if command -v whiptail >/dev/null 2>&1; then
    local choice
    choice="$(whiptail --title "Server Type" --menu "Choose the server type" 15 90 3 \
      "vanilla" "Vanilla Minecraft" \
      "fabric" "Fabric Minecraft" \
      "paper" "Paper Minecraft" 3>&1 1>&2 2>&3)" || true
    if [[ -n "$choice" ]]; then
      echo "$choice"
      return 0
    fi
  fi
  local server_type=""
  while [[ "$server_type" != "vanilla" && "$server_type" != "fabric" && "$server_type" != "paper" ]]; do
    read -rp "Choose the server type [vanilla/fabric/paper]: " server_type
    server_type="${server_type,,}"
  done
  echo "$server_type"
}

prompt_operator_name() {
  if command -v whiptail >/dev/null 2>&1; then
    local operator_name
    operator_name="$(whiptail --title "Operator Setup" --inputbox "Enter a player name to make operator (leave blank to skip)" 10 60 3>&1 1>&2 2>&3)" || true
    operator_name="${operator_name//[[:space:]]/}"
    echo "$operator_name"
    return 0
  fi

  local operator_name=""
  read -rp "Set operator username (leave blank to skip): " operator_name
  operator_name="${operator_name//[[:space:]]/}"
  echo "$operator_name"
}

prompt_version() {
  if command -v whiptail >/dev/null 2>&1; then
    local menu_args=()
    for version_value in "${SUPPORTED_VERSIONS[@]}"; do
      menu_args+=("$version_value" "$version_value")
    done
    local selected
    selected="$(whiptail --title "Minecraft Version" --menu "Select a version" 25 95 20 "${menu_args[@]}" 3>&1 1>&2 2>&3)" || true
    if [[ -n "$selected" ]]; then
      echo "$selected"
      return 0
    fi
  fi
  local version=""
  while :; do
    echo "Supported versions:"
    for version_value in "${SUPPORTED_VERSIONS[@]}"; do
      printf ' - %s\n' "$version_value"
    done
    read -rp "Select a version: " version
    if is_supported_version "$version"; then
      echo "$version"
      return 0
    fi
    echo "Unsupported version. Please choose one from the list above."
  done
}

resolve_version() {
  local requested="$1"
  echo "$requested"
}

select_java_version() {
  local resolved="$1"
  case "$resolved" in
    1.20.4|1.20.5|1.20.6|1.21|1.21.1|1.21.2|1.21.3)
      echo "17"
      ;;
    1.21.4|1.21.5|1.21.6|1.21.7|1.21.8|1.21.9|1.21.10|1.21.11)
      echo "21"
      ;;
    "26.1"|"26.1.1"|"26.1.2"|"26.2")
      echo "25      screen -r mc"
      ;;
    *)
      echo "21"
      ;;
  esac
}

install_prerequisites() {
  export DEBIAN_FRONTEND=noninteractive
  apt-get update || true
  apt-get install -y curl jq ca-certificates screen unzip whiptail wget python3 || true
  if ! command -v curl >/dev/null 2>&1; then
    apt-get install -y curl || true
  fi
  if ! command -v jq >/dev/null 2>&1; then
    apt-get install -y jq || true
  fi
}

install_java() {
  local java_version="$1"
  export DEBIAN_FRONTEND=noninteractive
  case "$java_version" in
    17)
      apt-get install -y openjdk-17-jdk-headless || apt-get install -y openjdk-17-jre-headless || true
      ;;
    25)
      apt-get install -y openjdk-25-jdk-headless || apt-get install -y openjdk-25-jre-headless || true
      apt-get install -y openjdk-21-jdk-headless || true
      ;;
    *)
      apt-get install -y openjdk-21-jdk-headless || apt-get install -y openjdk-21-jre-headless || true
      ;;
  esac
  if command -v java >/dev/null 2>&1; then
    java -version >/dev/null 2>&1 || true
  fi
}

detect_java_home() {
  local java_version="$1"
  local java_bin
  if command -v java >/dev/null 2>&1; then
    java_bin="$(readlink -f "$(command -v java)" 2>/dev/null || true)"
    if [[ -n "$java_bin" ]]; then
      echo "$(dirname "$(dirname "$java_bin")")"
      return 0
    fi
  fi

  local candidates=(
    "/usr/lib/jvm/java-${java_version}-openjdk-arm64"
    "/usr/lib/jvm/java-${java_version}-openjdk-armhf"
    "/usr/lib/jvm/java-${java_version}-openjdk-amd64"
    "/usr/lib/jvm/java-${java_version}-openjdk"
    "/usr/lib/jvm/java-25-openjdk"
    "/usr/lib/jvm/java-21-openjdk"
    "/usr/lib/jvm/java-17-openjdk"
    "/usr/lib/jvm/default-java"
  )
  for candidate in "${candidates[@]}"; do
    if [[ -d "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done
  echo "/usr/bin"
}

download_vanilla() {
  local resolved="$1"
  local manifest_url
  manifest_url="$(curl -fsSL https://launchermeta.mojang.com/mc/game/version_manifest.json | jq -r --arg version "$resolved" '.versions[] | select(.id==$version) | .url')"
  if [[ -z "$manifest_url" ]]; then
    echo "Could not resolve the official Mojang manifest for $resolved"
    exit 1
  fi
  local server_url
  server_url="$(curl -fsSL "$manifest_url" | jq -r '.downloads.server.url')"
  curl -fsSL "$server_url" -o "$SERVER_ROOT/server.jar"
}

download_fabric() {
  local resolved="$1"
  mkdir -p "$SERVER_ROOT"
  rm -f "$SERVER_ROOT/server.jar"
  rm -f "$SERVER_ROOT/fabric-server-launch.jar"
  local installer_jar="$SERVER_ROOT/fabric-installer.jar"
  local loader_json
  loader_json="$(curl -fsSL "https://meta.fabricmc.net/v2/versions/loader/$resolved")"
  local loader_version
  loader_version="$(printf '%s\n' "$loader_json" | jq -r '.[0].loader.version // empty')"
  local installer_version
  installer_version="$(printf '%s\n' "$loader_json" | jq -r '.[0].launcherMeta.version // .[0].version // "latest"')"
  if [[ -z "$loader_version" ]]; then
    echo "Could not resolve Fabric loader for $resolved"
    exit 1
  fi

  curl -fsSL "https://maven.fabricmc.net/net/fabricmc/fabric-installer/1.0.1/fabric-installer-1.0.1.jar" -o "$installer_jar"

  if ! (cd "$SERVER_ROOT" && java -jar "$installer_jar" server -mcversion "$resolved" -loader "$loader_version" -downloadMinecraft >/dev/null 2>&1); then
    echo "Fabric installer failed for $resolved; trying fallback mode."
    (cd "$SERVER_ROOT" && java -jar "$installer_jar" server -mcversion "$resolved" -loader "$loader_version" -installer "$installer_version" -downloadMinecraft >/dev/null 2>&1) || true
  fi

  mkdir -p "$SERVER_ROOT/mods" "$SERVER_ROOT/config" "$SERVER_ROOT/defaultconfigs" "$SERVER_ROOT/logs" "$SERVER_ROOT/plugins"
  if [[ -f "$SERVER_ROOT/fabric-server-launch.jar" ]]; then
    cp "$SERVER_ROOT/fabric-server-launch.jar" "$SERVER_ROOT/server.jar"
    return 0
  fi
  if [[ -f "$SERVER_ROOT/server.jar" ]]; then
    return 0
  fi

  echo "Fabric server jar was not produced for $resolved"
  exit 1
}

download_paper() {
  local resolved="$1"
  mkdir -p "$SERVER_ROOT"
  local builds_json
  builds_json="$(curl -fsSL "https://api.papermc.io/v2/projects/paper/versions/$resolved" 2>/dev/null || true)"
  local build
  build="$(printf '%s\n' "$builds_json" | jq -r '.builds[-1] // empty' 2>/dev/null || true)"
  if [[ -z "$build" ]]; then
    echo "Could not resolve a Paper build for $resolved; falling back to a direct URL attempt."
    if curl -fsSL "https://api.papermc.io/v2/projects/paper/versions/$resolved/builds/latest/downloads/paper-$resolved-latest.jar" -o "$SERVER_ROOT/server.jar" 2>/dev/null; then
      return 0
    fi
    echo "Paper download failed for $resolved"
    exit 1
  fi
  curl -fsSL "https://api.papermc.io/v2/projects/paper/versions/$resolved/builds/$build/downloads/paper-$resolved-$build.jar" -o "$SERVER_ROOT/server.jar"
}

write_server_files() {
  local operator_name="$1"
  mkdir -p "$SERVER_ROOT"
  mkdir -p "$SERVER_ROOT/mods" "$SERVER_ROOT/config" "$SERVER_ROOT/defaultconfigs" "$SERVER_ROOT/logs" "$SERVER_ROOT/plugins"
  cat > "$SERVER_ROOT/eula.txt" <<'EOF'
eula=true
EOF

  cat > "$SERVER_ROOT/server.properties" <<'EOF'
allow-flight=false
enable-command-block=false
gamemode=survival
level-name=world
motd=Raspberry Pi Minecraft Server
online-mode=true
spawn-protection=16
view-distance=10
max-players=10
difficulty=normal
pvp=true
EOF

  if [[ -n "$operator_name" ]]; then
    cat > "$SERVER_ROOT/ops.json" <<EOF
[
  {
    "uuid": "00000000-0000-0000-0000-000000000000",
    "name": "$operator_name",
    "level": 4,
    "bypassesPlayerLimit": false
  }
]
EOF
    printf '%s
' "$operator_name" > "$SERVER_ROOT/ops.txt"
  else
    rm -f "$SERVER_ROOT/ops.json" "$SERVER_ROOT/ops.txt"
  fi

  cat > "$SERVER_ROOT/start.sh" <<EOF
#!/usr/bin/env bash
set -euo pipefail
cd "$SERVER_ROOT"
mkdir -p "$SERVER_ROOT/mods" "$SERVER_ROOT/config" "$SERVER_ROOT/defaultconfigs" "$SERVER_ROOT/logs" "$SERVER_ROOT/plugins"
if command -v java >/dev/null 2>&1; then
  exec java -Xms256M -Xmx1536M -jar "$SERVER_ROOT/server.jar" --nogui
else
  echo "Java is not installed. Please rerun the installer."
  exit 1
fi
EOF
  chmod +x "$SERVER_ROOT/start.sh"
}

write_systemd_service() {
  local java_home="$1"
  ensure_systemd || true
  cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=Raspberry Pi Minecraft Server
After=network.target

[Service]
Type=simple
User=$RUN_USER
WorkingDirectory=$SERVER_ROOT
ExecStart=$java_home/bin/java -Xms256M -Xmx1536M -jar $SERVER_ROOT/server.jar --nogui
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF
  if command -v systemctl >/dev/null 2>&1; then
    install -m 0644 "$SERVICE_FILE" /etc/systemd/system/minecraft-server.service
    systemctl daemon-reload >/dev/null 2>&1 || true
    systemctl enable minecraft-server.service >/dev/null 2>&1 || true
    systemctl start minecraft-server.service >/dev/null 2>&1 || true
  fi
}

show_startup_logs() {
  if command -v screen >/dev/null 2>&1 && command -v journalctl >/dev/null 2>&1 && [[ -t 0 ]]; then
    screen -wipe >/dev/null 2>&1 || true
    screen -dmS minecraft-logs bash -lc 'journalctl -u minecraft-server.service -f --no-pager' >/dev/null 2>&1 || true
    sleep 2
    echo "Attaching to the Minecraft startup log screen..."
    screen -r minecraft-logs || true
  fi
}

fix_runtime_permissions() {
  if [[ -d "$SERVER_ROOT" ]]; then
    if [[ "$RUN_USER" != "root" ]]; then
      chown -R "$RUN_USER":"$RUN_USER" "$SERVER_ROOT" 2>/dev/null || true
    fi
    chmod -R u+rwX,g+rX,o-rwx "$SERVER_ROOT" 2>/dev/null || true
  fi
}

configure_overclock() {
  local model
  model="$(cat /proc/device-tree/model 2>/dev/null || true)"
  if [[ -z "$model" ]]; then
    echo "Raspberry Pi model could not be detected. Skipping overclock."
    return 0
  fi

  local config_file=""
  if [[ -f /boot/firmware/config.txt ]]; then
    config_file="/boot/firmware/config.txt"
  elif [[ -f /boot/config.txt ]]; then
    config_file="/boot/config.txt"
  fi

  if [[ -z "$config_file" ]]; then
    echo "No Raspberry Pi config file found. Skipping overclock."
    return 0
  fi

  local settings=""
  case "$model" in
    *"Raspberry Pi 4"*)
      settings=$'arm_freq=1800\ngpu_freq=750\nover_voltage=6\nforce_turbo=1\n'
      ;;
    *"Raspberry Pi 3"*)
      settings=$'arm_freq=1400\nover_voltage=4\n'
      ;;
    *"Raspberry Pi 5"*)
      settings=$'arm_freq=2200\ngpu_freq=800\nover_voltage=6\nforce_turbo=1\n'
      ;;
    *)
      settings=$'arm_freq=1500\nover_voltage=4\n'
      ;;
  esac

  if ! grep -q "# Added by pinecraft installer" "$config_file" 2>/dev/null; then
    cat >> "$config_file" <<EOF

# Added by pinecraft installer
$settings
EOF
  fi

  echo "Overclock profile written to $config_file for $model"
}

main() {
  require_supported_linux
  require_root
  install_prerequisites

  echo "Welcome to the Raspberry Pi multi-version Minecraft installer."
  if ! prompt_yes_no "Do you accept the Minecraft EULA?"; then
    echo "The installation was cancelled because the EULA was not accepted."
    exit 1
  fi

  local operator_name
  operator_name="$(prompt_operator_name)"
  local version
  version="$(prompt_version)"
  local resolved_version
  resolved_version="$(resolve_version "$version")"
  local server_type
  server_type="$(prompt_server_type)"
  local java_version
  java_version="$(select_java_version "$resolved_version")"

  install_java "$java_version"
  local java_home
  java_home="$(detect_java_home "$java_version")"

  write_server_files "$operator_name"
  case "$server_type" in
    vanilla)
      download_vanilla "$resolved_version"
      ;;
    fabric)
      download_fabric "$resolved_version"
      ;;
    paper)
      download_paper "$resolved_version"
      ;;
  esac

  fix_runtime_permissions
  write_systemd_service "$java_home"

  if prompt_yes_no "Would you like to overclock your Raspberry Pi now?"; then
    configure_overclock
  fi

  show_startup_logs

  cat > "$SERVER_ROOT/README.txt" <<EOF
Installed version: $resolved_version
Server type: $server_type
Java version: $java_version
Service: minecraft-server.service
Start: systemctl start minecraft-server.service
Logs: journalctl -u minecraft-server.service -f
Fabric note: this installer prepares a Fabric server directory. Put Fabric mods into the mods/ folder manually.
EOF

  echo "Installation complete."
  echo "Server files are in: $SERVER_ROOT"
  if command -v systemctl >/dev/null 2>&1; then
    echo "Start the server with: systemctl start minecraft-server.service"
    echo "Watch logs with: journalctl -u minecraft-server.service -f"
  else
    echo "Start the server with: ./server/start.sh"
  fi
}

main "$@"
